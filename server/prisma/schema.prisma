generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String @id @default(cuid())
  name         String
  email        String @unique
  passwordHash String

  // Roles match your frontend/backend codes
  role   String @default("CUSTOMER") // ADMIN | CUSTOMER | DRIVER
  status String @default("ACTIVE") // ACTIVE | INACTIVE

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // relations
  vehicles Vehicle[] @relation("DriverVehicles")

  // Shipments where this user is the DRIVER
  driverShipments Shipment[] @relation("DriverShipments")

  // Shipments where this user is the CUSTOMER/owner
  customerShipments Shipment[] @relation("CustomerShipments")
}

model Message {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Vehicle {
  id String @id @default(cuid())

  // What you show in UI like TRK-1021
  vehicleNo String @unique

  type   String
  status String @default("AVAILABLE") // AVAILABLE | IN_TRANSIT | MAINTENANCE

  driverName String?
  lastSeen   String?

  // Optional: connect vehicle to a User (driver)
  driverId String?
  driver   User?   @relation("DriverVehicles", fields: [driverId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([driverId])
}

model Shipment {
  id String @id @default(cuid())

  // What you show in UI like SH-1021 or #SHP-001
  shipmentNo String @unique

  client      String
  origin      String
  destination String

  status String  @default("PENDING") // PENDING | IN_TRANSIT | DELIVERED | DELAYED
  eta    String?

  driverName String?

  // Driver relation (named)
  driverId String?
  driver   User?   @relation("DriverShipments", fields: [driverId], references: [id], onDelete: SetNull)

  // Customer relation (named) — optional so old records won’t break
  customerId String?
  customer   User?   @relation("CustomerShipments", fields: [customerId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([driverId])
  @@index([customerId])
}
